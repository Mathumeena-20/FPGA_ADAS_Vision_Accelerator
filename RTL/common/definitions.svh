 `ifndef DEFINITIONS_SVH
`define DEFINITIONS_SVH

// Image size
`define IMG_WIDTH      640
`define IMG_HEIGHT     480

// Pixel width
`define PIXEL_WIDTH    8

// RGB width
`define RGB_WIDTH      24

// Frame size
`define FRAME_SIZE (`IMG_WIDTH * `IMG_HEIGHT)

// Threshold values
`define EDGE_THRESHOLD 50

// FIFO depth
`define FIFO_DEPTH     1024

// Clock frequency
`define CLK_FREQ       50000000

`endif